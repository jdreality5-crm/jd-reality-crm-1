.ic{background:#fff;border-radius:var(--rad);border:1px solid var(--bd);padding:22px;margin-bottom:16px;box-shadow:var(--sh);}
.ic h4{font-size:15px;font-weight:800;color:var(--dk);margin-bottom:8px;}
.ic p{font-size:13px;color:var(--tx2);margin-bottom:14px;line-height:1.7;}
.ic-g{border-color:var(--g);background:linear-gradient(135deg,#ecfdf5,#d1fae5);}
.ic-g h4{color:#065f46;}
.rg{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:18px;margin-bottom:22px;}
.rc{background:#fff;border-radius:var(--rad);border:1px solid var(--bd);padding:22px;box-shadow:var(--sh);}
.rc h4{font-size:13px;font-weight:800;color:var(--dk);margin-bottom:16px;}
.br{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
.br-l{font-size:12px;color:var(--tx2);min-width:90px;font-weight:600;}
.br-t{flex:1;height:8px;background:var(--bg2);border-radius:4px;overflow:hidden;}
.br-f{height:100%;border-radius:4px;transition:width .6s ease;}
.br-v{font-size:12px;font-weight:800;color:var(--dk);min-width:26px;text-align:right;}
.fs2{display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--bd);}
.fs2:last-child{border:none;}
.fs2-ic{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.fs2-l{font-size:13px;font-weight:700;color:var(--dk);}
.fs2-s{font-size:11px;color:var(--tx3);}
.fs2-c{margin-left:auto;font-size:22px;font-weight:900;color:var(--dk);}

/* IMAGE */
.imgprev{width:100%;max-height:180px;object-fit:contain;border-radius:10px;border:1.5px solid var(--bd);margin-top:9px;display:none;background:var(--bg2);}
.imgprev.on{display:block;}
.thumb{width:36px;height:36px;border-radius:8px;object-fit:cover;border:1px solid var(--bd);vertical-align:middle;}

/* VIEW ROW */
.vrow{display:flex;justify-content:space-between;padding:9px 0;border-bottom:1px solid var(--bd);font-size:13px;}
.vrow:last-child{border:none;}
.vrow span:first-child{color:var(--tx3);font-weight:700;}
.vrow span:last-child{color:var(--tx);font-weight:600;text-align:right;}

/* PROPERTY PAGE */
.prop-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:18px;}
.prop-card{background:#fff;border-radius:var(--rad);border:1px solid var(--bd);overflow:hidden;box-shadow:var(--sh);transition:var(--tr);}
.prop-card:hover{box-shadow:var(--shm);transform:translateY(-3px);}
.prop-img{width:100%;height:160px;object-fit:cover;background:var(--bg2);display:flex;align-items:center;justify-content:center;font-size:40px;}
.prop-body{padding:14px 16px;}
.prop-nm{font-size:14px;font-weight:800;color:var(--dk);}
.prop-meta{font-size:11px;color:var(--tx3);margin-top:4px;}
.prop-actions{padding:10px 16px;border-top:1px solid var(--bd);display:flex;gap:8px;}

/* WA PAGE */
.wa-tpl{background:#fff;border-radius:var(--rad);border:1px solid var(--bd);padding:18px;margin-bottom:14px;box-shadow:var(--sh);cursor:pointer;transition:var(--tr);}
.wa-tpl:hover{border-color:var(--p);background:var(--pl);}
.wa-tpl.sel{border-color:var(--p);background:var(--pl);box-shadow:0 0 0 3px rgba(79,70,229,.1);}
.wa-tpl-h{font-size:13px;font-weight:800;color:var(--dk);margin-bottom:6px;}
.wa-tpl-p{font-size:12px;color:var(--tx2);line-height:1.6;}

/* RESPONSIVE */
@media(max-width:768px){
  .sb{width:272px;transform:translateX(-100%);}
  .sb.on{transform:translateX(0);}
  .main{margin-left:0;}
  .hbg{display:flex;}
  .fg{grid-template-columns:1fr;}
  .sg{grid-template-columns:repeat(2,1fr);}
  .pc{padding:14px 16px;}
  .tb{padding:0 16px;}
  .sb2 input{width:100%;}
  .tt{flex-direction:column;align-items:stretch;}
  .sb2,.fsel{width:100%;}
  .tb-date{display:none;}
  table{font-size:12px;}
  thead th,tbody td{padding:9px 11px;}
  .mo{max-width:100%;border-radius:18px;}
  .fuc{flex-direction:column;align-items:flex-start;}
  .fu-btns{flex-direction:row;}
  .tg{grid-template-columns:repeat(2,1fr);}
  #login{flex-direction:column;}
  .ll{padding:28px 20px;flex:none;}
  .lr{width:100%;padding:28px 20px 40px;}
  .sg{grid-template-columns:repeat(2,1fr);}
}
@media(min-width:769px){.sb{transform:translateX(0)!important;}}
</style>
