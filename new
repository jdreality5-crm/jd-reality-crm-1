async function dbSU(u){
  try{
    // Compress avatar if present — keep under 30KB for Supabase
    let obj={...u};
    if(obj.avatar&&obj.avatar.startsWith('data:image')&&obj.avatar.length>30000){
      obj.avatar=await compressImg(obj.avatar,120,0.70);
    }
    if(obj.avatar&&obj.avatar.length>30000) obj.avatar=await compressImg(obj.avatar,80,0.60);

    // Check if user already exists by email
    const{data:existing,error:fetchErr}=await sb.from('users').select('id').eq('email',obj.email).maybeSingle();
    if(fetchErr){console.error('dbSU fetch error:',fetchErr.message,fetchErr.details||'');return false;}

    let saveError;
    if(existing){
      // UPDATE existing user — don't change id
      const{id,...updateFields}=obj;
      const{error}=await sb.from('users').update(updateFields).eq('email',obj.email);
      saveError=error;
    } else {
      // INSERT new user — remove id so Supabase auto-generates if needed, or keep string id
      const{error}=await sb.from('users').insert(obj);
      saveError=error;
    }

    if(saveError){console.error('dbSU error:',saveError.message,saveError.details||'',saveError.hint||'');return false;}
    showSy();return true;
  }catch(e){console.error('dbSU exception:',e);return false;}
}
