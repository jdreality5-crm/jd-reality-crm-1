.tc-nm{font-size:16px;font-weight:800;color:var(--dk);}
.tc-role{font-size:12px;color:var(--tx3);margin-bottom:14px;}
.tc-div{border:none;border-top:1px solid var(--bd);margin:12px 0;}
.tc-s{display:flex;justify-content:space-between;font-size:13px;color:var(--tx2);padding:4px 0;}
.tc-sv{font-weight:800;color:var(--dk);}
.admbdg{display:inline-block;padding:3px 12px;background:var(--grad);color:#fff;border-radius:20px;font-size:10px;font-weight:800;}

/* TABS */
.tabs{display:flex;border-bottom:2px solid var(--bd);margin-bottom:20px;}
