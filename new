function renderEnq(){
  const q=(document.getElementById('eq-s').value||'').toLowerCase();
  const fs=document.getElementById('eq-st').value,fsrc=document.getElementById('eq-src').value,fa=document.getElementById('eq-ag').value;
  let list=AL.filter(l=>{
    if(CU&&CU.type!=='admin'&&l.assign!==CU.email)return false;
    // Lost leads: sirf tab dikhao jab explicitly 'Lost' filter select ho
    if(!fs&&l.status==='Lost')return false;
    if(fs&&l.status!==fs)return false;
    if(fsrc&&l.source!==fsrc)return false;
    if(fa&&l.assign!==fa)return false;
    if(q&&!((l.name||'').toLowerCase().includes(q)||(l.phone||'').includes(q)||(l.area||'').toLowerCase().includes(q)))return false;
    return true;
  });
  renderEnqList(list);
}

