.btn-g{background:linear-gradient(135deg,#059669,#10b981);color:#fff;}
.btn-g:hover{box-shadow:0 4px 16px rgba(5,150,105,.4);}
.btn-o2{background:#fff;color:var(--p);border:1.5px solid var(--p);}
.btn-o2:hover{background:var(--pl);}
.btn-gh{background:var(--bg2);color:var(--tx2);border:1px solid var(--bd);}
.btn-gh:hover{background:var(--bd);}
.btn-wa{background:linear-gradient(135deg,#25D366,#128C7E);color:#fff;}
.btn-wa:hover{box-shadow:0 4px 16px rgba(37,211,102,.4);}
.btn-r{background:linear-gradient(135deg,#dc2626,#ef4444);color:#fff;}
.btn-sm{padding:6px 13px;font-size:12px;}
.lc{padding:10px 18px;font-size:12px;font-weight:700;color:var(--tx2);background:#fafbff;border-bottom:1px solid var(--bd);}

/* TABLE */
table{width:100%;border-collapse:collapse;}
thead th{background:var(--grad2);color:rgba(255,255,255,.75);padding:11px 15px;text-align:left;font-size:10px;font-weight:700;white-space:nowrap;text-transform:uppercase;letter-spacing:.8px;}
tbody tr{border-bottom:1px solid var(--bd);}
tbody tr:last-child{border-bottom:none;}
tbody tr:hover{background:#f8faff;}
tbody td{padding:11px 15px;font-size:13px;vertical-align:middle;}
.ln{color:var(--p);cursor:pointer;font-weight:700;}
.ln:hover{text-decoration:underline;}
.stag{display:inline-block;padding:2px 10px;border-radius:20px;font-size:10px;font-weight:700;}
.t-mb{background:#fff7ed;color:#c2410c;border:1px solid #fed7aa;}
.t-99{background:#fef2f2;color:#dc2626;border:1px solid #fecaca;}
.t-jd{background:var(--pl);color:var(--p);border:1px solid var(--pm);}
.t-ref{background:var(--gl);color:#059669;border:1px solid #a7f3d0;}
.t-walk{background:var(--pul);color:#7c3aed;border:1px solid #ddd6fe;}
.t-housing{background:#fef3c7;color:#92400e;border:1px solid #fde68a;}
.sp{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;}
.sp::before{content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0;}
.s-new{background:#eef2ff;color:#4338ca;}.s-new::before{background:#4f46e5;}
.s-active{background:#ecfdf5;color:#065f46;}.s-active::before{background:#059669;}
.s-warm{background:#fff7ed;color:#c2410c;}.s-warm::before{background:#ea580c;}
.s-follow-up{background:#fdf4ff;color:#86198f;}.s-follow-up::before{background:#d946ef;}
.s-site-visit{background:#fffbeb;color:#92400e;}.s-site-visit::before{background:#f59e0b;}
.s-negotiation{background:#f5f3ff;color:#5b21b6;}.s-negotiation::before{background:#7c3aed;}
.s-closed{background:#ecfdf5;color:#065f46;border:1px solid #a7f3d0;}.s-closed::before{background:#059669;}
.s-lost{background:#fef2f2;color:#991b1b;}.s-lost::before{background:#dc2626;}
.s-booking-done{background:#fffbeb;color:#92400e;border:1px solid #fcd34d;}.s-booking-done::before{background:#f59e0b;}
.ia{background:none;border:none;cursor:pointer;padding:5px 7px;border-radius:7px;font-size:15px;transition:var(--tr);}
.ia:hover{background:var(--bg2);}

/* MODALS */
.ov{display:none;position:fixed;inset:0;background:rgba(10,15,30,.65);z-index:700;align-items:center;justify-content:center;padding:16px;backdrop-filter:blur(6px);}
.ov.on{display:flex;}
.mo{background:#fff;border-radius:20px;width:100%;max-width:600px;max-height:92vh;overflow-y:auto;box-shadow:var(--shl);}
.mh{display:flex;align-items:center;justify-content:space-between;padding:20px 24px;border-bottom:1px solid var(--bd);position:sticky;top:0;background:#fff;z-index:10;border-radius:20px 20px 0 0;}
.mh-l{display:flex;align-items:center;gap:12px;}
.mh-ic{width:40px;height:40px;border-radius:11px;background:var(--pl);display:flex;align-items:center;justify-content:center;font-size:18px;}
.mh h3{font-size:16px;font-weight:800;color:var(--dk);}
.mh p{font-size:11px;color:var(--tx3);margin-top:2px;}
.mx{background:var(--bg2);border:none;color:var(--tx2);font-size:15px;cursor:pointer;width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;transition:var(--tr);}
