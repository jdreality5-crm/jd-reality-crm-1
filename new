.at{width:100%;border-collapse:collapse;font-size:13px;}
.at th{background:var(--bg2);color:var(--tx2);padding:10px 15px;text-align:left;font-weight:800;font-size:10px;text-transform:uppercase;letter-spacing:.8px;}
.at td{padding:12px 15px;border-bottom:1px solid var(--bd);}
.at tr:last-child td{border:none;}
.at tr:hover td{background:#f8faff;}

