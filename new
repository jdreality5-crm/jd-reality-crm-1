function renderCalendarView(){
  const months=['January','February','March','April','May','June','July','August','September','October','November','December'];
  const days=['SUN','MON','TUE','WED','THU','FRI','SAT'];
  const monthLabel=document.getElementById('cal-month-label');
  if(monthLabel)monthLabel.textContent=months[calMonth]+' '+calYear;
  const miniMonth=document.getElementById('cal-mini-month');
  if(miniMonth)miniMonth.textContent=months[calMonth]+' '+calYear;
  const first=new Date(calYear,calMonth,1).getDay();
  const total=new Date(calYear,calMonth+1,0).getDate();
  const td=today();
  let html=`<div class="cal-grid" style="margin-bottom:8px">${days.map(d=>`<div class="cal-day-hdr">${d}</div>`).join('')}</div>`;
  html+=`<div class="cal-grid">`;
  // Mini calendar HTML
  let miniHtml='';
  let monthFuCount=0;
  for(let i=0;i<first;i++){html+=`<div></div>`;miniHtml+=`<div></div>`;}
  // Role-based filtering: admin sees all leads, agent sees only their assigned leads
  const calLeads=(CU&&CU.type!=='admin')?AL.filter(l=>l.assign===CU.email):AL;
  // Total leads count for mini info (all statuses)
  const totalLeadsCount=calLeads.length;
  for(let d=1;d<=total;d++){
    const dateStr=calYear+'-'+String(calMonth+1).padStart(2,'0')+'-'+String(d).padStart(2,'0');
    const cnt=calLeads.filter(l=>l.next_call===dateStr&&l.status!=='Closed'&&l.status!=='Lost').length;
    monthFuCount+=cnt;
    const isToday=dateStr===td;
    const hasDot=cnt>0;
    let cls='cal-day';
    if(isToday)cls+=' cal-today';
    if(hasDot)cls+=' cal-has-leads';
    html+=`<div class="${cls}" onclick="calDayClick('${dateStr}','${d} ${months[calMonth]} ${calYear}')">
      <div class="cal-day-num">${d}</div>
      ${hasDot?`<div class="cal-badge">${cnt}</div>`:''}
    </div>`;
    // Mini calendar cell
    let miniCls='';
    let miniStyle='text-align:center;padding:2px 1px;border-radius:4px;font-size:9px;font-weight:600;cursor:default;';
    if(isToday)miniStyle+='background:var(--grad);color:#fff;';
    else if(hasDot)miniStyle+='background:var(--pl);color:var(--p);font-weight:800;';
    else miniStyle+='color:var(--tx3);';
    miniHtml+=`<div style="${miniStyle}">${d}</div>`;
  }
  html+='</div>';
  const calBody=document.getElementById('d-calendar');
  if(calBody)calBody.innerHTML=html;
  // Render mini grid
  const miniGrid=document.getElementById('cal-mini-grid');
  if(miniGrid)miniGrid.innerHTML=miniHtml;
  const miniInfo=document.getElementById('cal-mini-info');
  if(miniInfo)miniInfo.textContent=`${totalLeadsCount} total lead${totalLeadsCount!==1?'s':''}`;
}

function calDayClick(dateStr,label){
  const calLeads=(CU&&CU.type!=='admin')?AL.filter(l=>l.assign===CU.email):AL;
  const leads=calLeads.filter(l=>l.next_call===dateStr&&l.status!=='Closed'&&l.status!=='Lost');
  const panel=document.getElementById('cal-leads-panel');
  document.getElementById('cal-panel-title').textContent=`📅 ${label} — ${leads.length} Lead${leads.length!==1?'s':''}`;
  if(!leads.length){document.getElementById('cal-leads-list').innerHTML='<div style="text-align:center;padding:2rem;color:var(--tx3);font-size:13px">No leads on this date.</div>';panel.style.display='block';return;}
  document.getElementById('cal-leads-list').innerHTML=leads.map(l=>`<div style="display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid var(--bd)">
    <div style="flex:1"><div style="font-size:14px;font-weight:800;color:var(--dk)">${l.name}</div><div style="font-size:11px;color:var(--tx3)">${l.phone} · ${uname(l.assign)} · <span class="sp ${scls(l.status)}">${l.status}</span></div>${l.next_time?`<div style="font-size:11px;color:var(--p);font-weight:700">⏰ ${fmt12(l.next_time)}</div>`:''}</div>
    <div style="display:flex;gap:6px"><button class="btn btn-p btn-sm" onclick="openEdit('${l.id}')">✏️ Edit</button><button class="btn btn-wa btn-sm" onclick="waReminder('${l.id}')">💬</button></div>
  </div>`).join('');
  panel.style.display='block';
  setTimeout(()=>panel.scrollIntoView({behavior:'smooth',block:'nearest'}),50);
}

