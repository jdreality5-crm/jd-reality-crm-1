.fu-day{font-size:22px;font-weight:900;line-height:1;}
.fu-mon{font-size:9px;font-weight:800;text-transform:uppercase;letter-spacing:1px;}
.fu-time{font-size:10px;font-weight:700;margin-top:6px;padding:2px 8px;border-radius:5px;}
.fu-bd{flex:1;min-width:0;}
.fu-nm{font-size:14px;font-weight:800;color:var(--dk);}
.fu-mt{font-size:12px;color:var(--tx3);margin-top:2px;}
.ubadge{display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:5px;font-size:10px;font-weight:800;margin-left:8px;}
.fu-btns{display:flex;flex-direction:column;gap:5px;flex-shrink:0;}

/* TEAM */
.tg{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:18px;}
.tc{background:#fff;border-radius:var(--rad);border:1px solid var(--bd);padding:26px 20px;text-align:center;box-shadow:var(--sh);transition:var(--tr);}
