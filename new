.mb{padding:24px;}
.mf{display:flex;gap:9px;justify-content:flex-end;padding:16px 24px;border-top:1px solid var(--bd);background:#fafbff;border-radius:0 0 20px 20px;position:sticky;bottom:0;}
.fg{display:grid;grid-template-columns:1fr 1fr;gap:15px;margin-bottom:15px;}
