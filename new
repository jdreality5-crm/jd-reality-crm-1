.btn{padding:9px 18px;border-radius:var(--rad3);font-size:13px;font-weight:700;cursor:pointer;display:inline-flex;align-items:center;gap:7px;border:none;font-family:inherit;transition:var(--tr);white-space:nowrap;}
.btn-p{background:var(--grad);color:#fff;}
