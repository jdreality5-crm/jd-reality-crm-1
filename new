.fr input:focus,.fr select:focus,.fr textarea:focus{border-color:var(--p);background:#fff;box-shadow:0 0 0 3px rgba(79,70,229,.08);}
.req{color:var(--r);}
.fs-h{font-size:10px;font-weight:800;color:var(--tx3);text-transform:uppercase;letter-spacing:1.5px;margin:20px 0 13px;padding-bottom:8px;border-bottom:1px solid var(--bd);}
.clog{border:1.5px solid var(--bd);border-radius:10px;padding:12px;background:var(--bg);max-height:180px;overflow-y:auto;margin-bottom:10px;}
.ce{padding:8px 0;border-bottom:1px solid var(--bd);}
.ce:last-child{border:none;}
.ce-by{font-weight:800;color:var(--p);font-size:12px;}
.ce-dt{color:var(--tx3);font-size:10px;margin-left:6px;}
.ce-t{font-size:12px;color:var(--tx2);margin-top:3px;line-height:1.6;}
.malert{font-size:12px;padding:10px 13px;border-radius:9px;margin-top:9px;font-weight:500;display:none;}
.malert.ok{background:var(--gl);color:#065f46;}
.malert.err{background:var(--rl);color:#991b1b;}

/* FOLLOW-UP CARDS */
.fuh{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:1.5px;margin:18px 0 10px;display:flex;align-items:center;gap:8px;}
.fuc{background:#fff;border-radius:var(--rad);border:1px solid var(--bd);padding:15px 18px;margin-bottom:9px;display:flex;align-items:center;gap:16px;box-shadow:var(--sh);transition:var(--tr);}
.fuc:hover{box-shadow:var(--shm);transform:translateX(2px);}
